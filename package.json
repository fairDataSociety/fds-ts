{
  "name": "@fairdatasociety/fds",
  "version": "1.1.0",
  "description": "Fair Data Society SDK — sovereign data for TypeScript. Identity, storage, messaging, sharing, exchange. Complete rewrite (legacy fds.js abandoned 2022).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fds": "dist/cli/index.js",
    "fds-mcp": "dist/mcp/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    },
    "./crypto": {
      "import": "./dist/crypto/index.js",
      "types": "./dist/crypto/index.d.ts"
    },
    "./identity": {
      "import": "./dist/identity/index.js",
      "types": "./dist/identity/index.d.ts"
    },
    "./access": {
      "import": "./dist/access/index.js",
      "types": "./dist/access/index.d.ts"
    },
    "./fairdrive": {
      "import": "./dist/fairdrive-exports.js",
      "types": "./dist/fairdrive-exports.d.ts"
    },
    "./fairdrive/node": {
      "import": "./dist/fairdrive-node.js",
      "types": "./dist/fairdrive-node.d.ts"
    },
    "./fairdrop": {
      "import": "./dist/fairdrop-exports.js",
      "types": "./dist/fairdrop-exports.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js",
      "types": "./dist/cli/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/index.js",
      "types": "./dist/mcp/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ethersphere/bee-js": "^11.0.0",
    "@fairdatasociety/fds-id": "^0.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/ciphers": "^1.0.0",
    "@noble/hashes": "^2.0.1",
    "@noble/secp256k1": "^3.0.0",
    "@scure/bip32": "^1.7.0",
    "@scure/bip39": "^1.6.0",
    "async-mutex": "^0.4.0",
    "chokidar": "^3.6.0",
    "ethers": "^6.0.0",
    "viem": "^2.0.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/fairDataSociety/fds-ts"
  },
  "keywords": [
    "fair-data",
    "swarm",
    "ethereum",
    "decentralized",
    "storage",
    "encryption",
    "identity",
    "escrow",
    "privacy",
    "web3",
    "sdk"
  ]
}
